{
  "name": "slimmia",
  "version": "0.1.0",
  "description": "Put your AI agents on a diet — scan, audit, slim, and sync AI agent environments.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jorgemoreno/slimmia.git"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "slimmia": "./dist/cli.js"
  },
